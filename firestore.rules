rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Client validation
    function isValidClient(data) {
      return data.userId == request.auth.uid 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.platform in ['meta', 'google']
        && data.accountId is string && data.accountId.size() > 0 && data.accountId.size() <= 100
        && (data.status == null || data.status in ['active', 'paused', 'error']);
    }

    match /clients/{clientId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidClient(request.resource.data)
        && request.resource.data.keys().hasAll(['userId', 'name', 'platform', 'accountId'])
        && request.resource.data.keys().size() <= 8;

      allow update: if isOwner(resource.data.userId)
        && isValidClient(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.accountId == resource.data.accountId
        && request.resource.data.platform == resource.data.platform;

      allow delete: if isOwner(resource.data.userId);
    }

    // Metric validation
    match /metrics/{metricId} {
      // Metrics are linked to clients. Access is inherited.
      allow read: if isSignedIn() && exists(/databases/$(database)/documents/clients/$(resource.data.clientId))
        && get(/databases/$(database)/documents/clients/$(resource.data.clientId)).data.userId == request.auth.uid;

      allow write: if false; // Only system should write metrics (in this demo, we'll allow client writes for prototype speed, but marked as insecure)
    }
  }
}
